            font-weight: 800;
            color: #333;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .legend-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 12px;
        }

        .legend-segment {
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .legend-dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            margin-top: 2px;
            flex: 0 0 18px;
