            const starHTML = starredConsulates.has(consulate.city) ?
                `<div class="marker-star">★</div>` :
                '';

            const markerHTML = `
                <div class="marker-wrapper">
                    <div class="main-marker-wrap">
                        <div class="main-marker" style="background:${sensitivityColors[consulate.category]}"></div>
                        ${starHTML}
                    </div>
                    <div class="party-row">
                        <div class="mini-triangle" style="border-bottom-color:${partyColors[consulate.mayor] || '#9e9e9e'}"></div>
                        <div class="mini-square" style="background:${partyColors[consulate.governor] || '#9e9e9e'}"></div>
                    </div>
                    <div class="marker-label">${consulate.city}</div>
                </div>`;

            const icon = L.divIcon({
                html: markerHTML,
                className: '',
                iconSize: [150, 62],
                iconAnchor: [75, 18]
            });

            const mediaHTML = mediaByCity[consulate.city]
                ? `<div class="media-box"><strong>Medios Importantes</strong><div class="media-lines">${mediaByCity[consulate.city]}</div></div>`
                : '';

            const popupHTML = `
                <div class="consulate-popup">
                    <div class="title">${consulate.city} Consulado</div>
                    <div class="row"><strong>Segmentación:</strong><br><span class="seg" style="background:${sensitivityColors[consulate.category]}">${segmentNames[consulate.category]}</span></div>
                    <div class="row"><strong>Alcalde:</strong> <span class="swatch" style="background:${partyColors[consulate.mayor] || '#9e9e9e'}"></span>${consulate.mayor}</div>
                    <div class="row"><strong>Gobernador:</strong> <span class="swatch" style="background:${partyColors[consulate.governor] || '#9e9e9e'}"></span>${consulate.governor}</div>
                    ${mediaHTML}
                </div>`;

            const marker = L.marker([consulate.lat, consulate.lng], {
                icon
            }).addTo(map).bindPopup(popupHTML);

            consulate.marker = marker;
        });

        const segmentFilter = document.getElementById('filter-segment');
        const mayorFilter = document.getElementById('filter-mayor');
        const governorFilter = document.getElementById('filter-governor');
        const resetButton = document.getElementById('reset-filters');

        function applyFilters() {
            const selectedSegment = segmentFilter.value;
            const selectedMayor = mayorFilter.value;
            const selectedGovernor = governorFilter.value;

            consulates.forEach(consulate => {
                const matchesSegment = selectedSegment === 'Todos' || consulate.category === selectedSegment;
                const matchesMayor = selectedMayor === 'Todos' || consulate.mayor === selectedMayor;
                const matchesGovernor = selectedGovernor === 'Todos' || consulate.governor === selectedGovernor;

                const shouldShow = matchesSegment && matchesMayor && matchesGovernor;

                if (shouldShow) {
                    if (!map.hasLayer(consulate.marker)) {
                        consulate.marker.addTo(map);
                    }
                } else {
                    if (map.hasLayer(consulate.marker)) {
                        map.removeLayer(consulate.marker);
                    }
                }
            });
        }

        segmentFilter.addEventListener('change', applyFilters);
        mayorFilter.addEventListener('change', applyFilters);
        governorFilter.addEventListener('change', applyFilters);

        resetButton.addEventListener('click', () => {
            segmentFilter.value = 'Todos';
            mayorFilter.value = 'Todos';
            governorFilter.value = 'Todos';
            applyFilters();
        });
